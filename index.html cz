<script>
/* ── STARS ── */
const starEmojis=['⭐','✨','🌟','💫','🌸','🍀','🌈'];
const sc=document.getElementById('starsContainer');
for(let i=0;i<16;i++){
  const s=document.createElement('div');s.className='star';
  s.textContent=starEmojis[Math.floor(Math.random()*starEmojis.length)];
  s.style.cssText=`left:${Math.random()*100}%;top:${Math.random()*100}%;font-size:${0.6+Math.random()*0.85}rem;animation-delay:${Math.random()*4}s;animation-duration:${2.5+Math.random()*2}s;`;
  sc.appendChild(s);
}

/* ── NAVIGATION ── */
const navMap={'screen-home':'nav-home','screen-feel':'nav-feel','screen-wisdom':'nav-wisdom','screen-story':'nav-story'};
function goTo(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  if(navMap[id]) document.getElementById(navMap[id]).classList.add('active');
  if(id==='screen-story') renderEntries('all'); // refresh journal on open
}

/* ── STORY TABS ── */
function switchTab(tabId, btn){
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.story-tab').forEach(b=>b.classList.remove('active'));
  document.getElementById(tabId).classList.add('active');
  btn.classList.add('active');
  if(tabId==='tab-wall') renderWall();
  if(tabId==='tab-journal') renderEntries('all');
}

/* ── JOURNAL STATE ── */
let currentFeeling = '';
let currentPrivacy = 'private';
let activeFilter   = 'all';

function pickFeeling(btn, feeling){
  document.querySelectorAll('.fp-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  currentFeeling = feeling;
}

function setPrivacy(type){
  currentPrivacy = type;
  document.getElementById('privBtn').className = 'privacy-btn' + (type==='private'?' selected-private':'');
  document.getElementById('pubBtn').className  = 'privacy-btn' + (type==='public' ?' selected-public':'');
}

/* ── SAVE ENTRY ── */
function saveEntry(){
  const text = document.getElementById('journalText').value.trim();
  if(!text){ alert('Nejdřív napiš něco do deníku 💛'); return; }

  const entry = {
    id:      Date.now(),
    feeling: currentFeeling || '💭 Bez štítku',
    text:    text,
    privacy: currentPrivacy,
    date:    new Date().toLocaleDateString('cs-CZ',{day:'numeric',month:'long',year:'numeric'})
  };

  const entries = getEntries();
  entries.unshift(entry);
  localStorage.setItem('wisdom_entries', JSON.stringify(entries));

  /* Reset form */
  document.getElementById('journalText').value='';
  document.querySelectorAll('.fp-btn').forEach(b=>b.classList.remove('selected'));
  currentFeeling=''; currentPrivacy='private';
  setPrivacy('private');

  /* Show confirm */
  const conf=document.getElementById('saveConfirm');
  conf.classList.add('show');
  setTimeout(()=>conf.classList.remove('show'),3500);

  renderEntries(activeFilter);
}

function getEntries(){
  try { return JSON.parse(localStorage.getItem('wisdom_entries')||'[]'); }
  catch(e){ return []; }
}

function deleteEntry(id){
  const entries = getEntries().filter(e=>e.id!==id);
  localStorage.setItem('wisdom_entries', JSON.stringify(entries));
  renderEntries(activeFilter);
  renderWall();
}

function filterEntries(type, btn){
  activeFilter=type;
  document.querySelectorAll('.ef-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderEntries(type);
}

function renderEntries(filter){
  const list=document.getElementById('entriesList');
  if(!list) return;
  let entries=getEntries();
  if(filter==='private') entries=entries.filter(e=>e.privacy==='private');
  if(filter==='public')  entries=entries.filter(e=>e.privacy==='public');

  if(!entries.length){
    list.innerHTML=`<div class="empty-journal"><span class="ej-icon">✏️</span><p>Zatím žádné zápisky.<br>Napiš svůj první — jsi odvážný/á! 🌱</p></div>`;
    return;
  }
  list.innerHTML=entries.map(e=>`
    <div class="entry-card ${e.privacy==='public'?'public-entry':''}">
      <button class="entry-delete" onclick="deleteEntry(${e.id})" title="Smazat">🗑️</button>
      <div class="entry-top">
        <span class="entry-feeling-tag ${e.privacy==='public'?'public':''}">${e.feeling} ${e.privacy==='public'?'🌍':'🔒'}</span>
        <span class="entry-date">${e.date}</span>
      </div>
      <div class="entry-text">${e.text.replace(/\n/g,'<br>')}</div>
    </div>`).join('');
}

function renderWall(){
  const wall=document.getElementById('wallList');
  if(!wall) return;
  const entries=getEntries().filter(e=>e.privacy==='public');
  if(!entries.length){
    wall.innerHTML=`<div class="empty-journal"><span class="ej-icon">🌍</span><p>Zatím tu nic není.<br>Buď první, kdo sdílí svůj zápis! 💛</p></div>`;
    return;
  }
  wall.innerHTML=entries.map(e=>`
    <div class="entry-card public-entry" style="margin:0 16px 10px">
      <div class="entry-top">
        <span class="entry-feeling-tag public">${e.feeling} 🌍</span>
        <span class="entry-date">${e.date}</span>
      </div>
      <div class="entry-text">${e.text.replace(/\n/g,'<br>')}</div>
    </div>`).join('');
}

